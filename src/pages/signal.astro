---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Signal"
  description="An interactive emerging tech tracker built on academic literature."
>

  <div class="mb-12">
    <p class="mono text-xs mb-4" style="color: #7fff6e;">SIGNAL</p>
    <h1 class="text-3xl font-semibold mb-4" style="color: #e8e8e8;">
      What's emerging in climate tech
    </h1>
    <p class="text-base leading-relaxed max-w-2xl" style="color: #888888;">
      Keywords extracted from peer-reviewed literature, filtered for commercial
      relevance, and scored across four dimensions: momentum, acceleration,
      recency, and citation velocity. Updated when the tracker runs.
    </p>
  </div>

  <!-- Meta bar -->
  <div id="meta-bar" class="mono text-xs mb-8 flex gap-6" style="color: #555;">
    <span id="meta-updated">–</span>
    <span id="meta-keywords">–</span>
    <span id="meta-range">–</span>
  </div>

  <!-- Domain filter -->
  <div id="domain-filter" class="flex flex-wrap gap-2 mb-8" style="display:none !important;">
    <button class="domain-btn active-domain mono text-xs px-3 py-1 rounded" data-domain="all">All domains</button>
  </div>

  <!-- Tab controls -->
  <div class="flex gap-2 mb-8" id="tab-controls">
    <button data-tab="board"  class="tab-btn active-tab mono text-xs px-4 py-2 rounded">Signal Board</button>
    <button data-tab="trends" class="tab-btn mono text-xs px-4 py-2 rounded">Trends</button>
    <button data-tab="map"    class="tab-btn mono text-xs px-4 py-2 rounded">Concept Map</button>
    <button data-tab="watch"  class="tab-btn mono text-xs px-4 py-2 rounded">Watchlist</button>
  </div>

  <!-- ── Signal Board ── -->
  <div id="tab-board" class="tab-panel">
    <p class="text-xs mb-4" style="color: #555;">
      Each bubble is a keyword. Size = research volume. Position: recency (x) vs composite score (y).
      Colour = trend shape. Click a bubble to drill in.
    </p>
    <div id="board-chart" style="width:100%;height:520px;position:relative;">
      <svg id="board-svg" width="100%" height="100%"></svg>
      <div id="board-tooltip"
           style="position:absolute;display:none;background:#161616;border:1px solid #2a2a2a;
                  border-radius:6px;padding:10px 14px;font-size:12px;pointer-events:none;max-width:240px;">
      </div>
    </div>
    <!-- Drill-down panel -->
    <div id="drill-panel" style="display:none;margin-top:24px;padding:20px;
         background:#161616;border:1px solid #2a2a2a;border-radius:8px;">
      <div class="flex justify-between items-start mb-4">
        <div>
          <p id="drill-keyword" class="text-base font-semibold" style="color:#e8e8e8;"></p>
          <p id="drill-meta"    class="mono text-xs mt-1" style="color:#555;"></p>
        </div>
        <button id="drill-close" class="mono text-xs" style="color:#555;">✕ close</button>
      </div>
      <div id="drill-chart" style="width:100%;height:180px;">
        <svg id="drill-svg" width="100%" height="100%"></svg>
      </div>
      <div id="drill-scores" class="grid grid-cols-4 gap-3 mt-4"></div>
    </div>
  </div>

  <!-- ── Trends table ── -->
  <div id="tab-trends" class="tab-panel" style="display:none;">
    <div class="flex gap-3 mb-5">
      <input id="trends-search" type="text" placeholder="Filter keywords…"
             class="mono text-xs px-3 py-2 rounded flex-1 max-w-xs"
             style="background:#161616;border:1px solid #2a2a2a;color:#e8e8e8;outline:none;" />
      <select id="trends-shape" class="mono text-xs px-3 py-2 rounded"
              style="background:#161616;border:1px solid #2a2a2a;color:#e8e8e8;outline:none;">
        <option value="">All shapes</option>
        <option value="emerging">Emerging</option>
        <option value="nascent">Nascent</option>
        <option value="stable">Stable</option>
        <option value="spike">Spike</option>
        <option value="declining">Declining</option>
      </select>
    </div>
    <div style="overflow-x:auto;">
      <table id="trends-table" style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead>
          <tr style="border-bottom:1px solid #2a2a2a;">
            <th class="mono text-left py-3 pr-6"   style="color:#555;font-weight:500;">KEYWORD</th>
            <th class="mono text-right py-3 px-3"  style="color:#555;font-weight:500;">SCORE</th>
            <th class="mono text-right py-3 px-3"  style="color:#555;font-weight:500;">M</th>
            <th class="mono text-right py-3 px-3"  style="color:#555;font-weight:500;">Ac</th>
            <th class="mono text-right py-3 px-3"  style="color:#555;font-weight:500;">R</th>
            <th class="mono text-right py-3 px-3"  style="color:#555;font-weight:500;">Cv</th>
            <th class="mono text-left py-3 px-3"   style="color:#555;font-weight:500;">SHAPE</th>
            <th class="mono text-left py-3 px-3"   style="color:#555;font-weight:500;">JOURNALS</th>
          </tr>
        </thead>
        <tbody id="trends-body"></tbody>
      </table>
    </div>
  </div>

  <!-- ── Concept Map ── -->
  <div id="tab-map" class="tab-panel" style="display:none;">
    <p class="text-xs mb-4" style="color: #555;">
      Force-directed graph of concept co-occurrence. Lines connect keywords that
      appear together in the same papers. Drag nodes to explore.
    </p>
    <div id="map-chart" style="width:100%;height:560px;position:relative;
         background:#0d0d0d;border:1px solid #2a2a2a;border-radius:8px;overflow:hidden;">
      <svg id="map-svg" width="100%" height="100%"></svg>
      <div id="map-tooltip"
           style="position:absolute;display:none;background:#161616;border:1px solid #2a2a2a;
                  border-radius:6px;padding:8px 12px;font-size:11px;pointer-events:none;">
      </div>
    </div>
  </div>

  <!-- ── Watchlist ── -->
  <div id="tab-watch" class="tab-panel" style="display:none;">
    <p class="text-xs mb-6 max-w-xl" style="color: #555;">
      Sub-threshold signals — keywords that didn't clear the frequency floor
      but were surfaced by semantic or string expansion methods.
      Low confidence. Requires human review.
    </p>
    <div id="watch-list" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3"></div>
  </div>

</Layout>

<script>
import * as d3 from 'd3';

// ── State ─────────────────────────────────────────────────────────────────────
let fullData: any   = null;   // raw signal_data.json
let expansionData: any = null;
let watchlistData: any = null;
let currentDomain   = 'all'; // selected domain key

const SHAPE_COLOR: Record<string, string> = {
  emerging:  '#7fff6e',
  nascent:   '#f5c842',
  stable:    '#888888',
  spike:     '#f5c842',
  declining: '#e05c5c',
  no_data:   '#444444',
};

// ── Helpers ───────────────────────────────────────────────────────────────────
function activeKeywords(): any[] {
  if (!fullData || !fullData.domains) return [];
  if (currentDomain === 'all') {
    return Object.values(fullData.domains).flatMap((d: any) => d.keywords);
  }
  return fullData.domains[currentDomain]?.keywords ?? [];
}

// ── Load data ─────────────────────────────────────────────────────────────────
async function loadAll() {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  try {
    const [sdRes, eRes, wRes] = await Promise.all([
      fetch(`${base}/data/signal_data.json`),
      fetch(`${base}/data/expansion.json`),
      fetch(`${base}/data/watchlist.json`),
    ]);
    fullData      = await sdRes.json();
    expansionData = (await eRes.json()).expansion ?? null;
    watchlistData = (await wRes.json()).watchlist ?? null;
  } catch {
    // data not yet available
  }

  updateMetaBar();
  buildDomainFilter();
  drawBoard();
  drawTrends();
  drawMap();
  drawWatchlist();
}

function updateMetaBar() {
  const updated = document.getElementById('meta-updated')!;
  const keywords = document.getElementById('meta-keywords')!;
  const range    = document.getElementById('meta-range')!;

  if (!fullData?.generated_at) {
    updated.textContent = 'data not yet loaded — run the tracker';
    return;
  }

  const date = new Date(fullData.generated_at);
  updated.textContent  = `updated ${date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}`;

  const totalKw = Object.values(fullData.domains ?? {}).reduce(
    (sum: number, d: any) => sum + (d.keyword_count ?? 0), 0
  );
  const domainCount = Object.keys(fullData.domains ?? {}).length;
  keywords.textContent = `${totalKw} keywords · ${domainCount} domains`;
  range.textContent    = `${fullData.year_from}–${fullData.year_to}`;
}

function buildDomainFilter() {
  const container = document.getElementById('domain-filter')!;
  if (!fullData?.domains || Object.keys(fullData.domains).length === 0) return;

  container.style.removeProperty('display');  // un-hide

  // Clear existing domain buttons (keep "All")
  container.querySelectorAll('[data-domain]:not([data-domain="all"])').forEach(el => el.remove());

  Object.entries(fullData.domains).forEach(([key, info]: [string, any]) => {
    const btn = document.createElement('button');
    btn.className   = 'domain-btn mono text-xs px-3 py-1 rounded';
    btn.dataset.domain = key;
    btn.textContent = info.label;
    container.appendChild(btn);
  });

  container.querySelectorAll('.domain-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentDomain = (btn as HTMLElement).dataset.domain!;
      container.querySelectorAll('.domain-btn').forEach(b => b.classList.remove('active-domain'));
      btn.classList.add('active-domain');
      drawBoard();
      renderTrendsTable();
    });
  });
}

// ── Tab switching ─────────────────────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = (btn as HTMLElement).dataset.tab!;
    document.querySelectorAll('.tab-panel').forEach(p => ((p as HTMLElement).style.display = 'none'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active-tab'));
    document.getElementById(`tab-${tab}`)!.style.display = 'block';
    btn.classList.add('active-tab');
  });
});

// ── Signal Board ──────────────────────────────────────────────────────────────
function drawBoard() {
  const container = document.getElementById('board-svg')!;
  const rect = container.getBoundingClientRect();
  const W = rect.width || 800;
  const H = 520;
  const pad = { top: 30, right: 30, bottom: 50, left: 55 };

  const svg = d3.select('#board-svg').attr('viewBox', `0 0 ${W} ${H}`);
  svg.selectAll('*').remove();

  const data = activeKeywords();

  if (data.length === 0) {
    svg.append('text').attr('x', W/2).attr('y', H/2)
      .attr('text-anchor', 'middle').attr('fill', '#444').attr('font-size', 13)
      .text('Run the tracker to populate this chart');
    return;
  }

  const xScale = d3.scaleLinear()
    .domain([0, 1]).range([pad.left, W - pad.right]);
  const yScale = d3.scaleLinear()
    .domain([0, 1]).range([H - pad.bottom, pad.top]);
  const rScale = d3.scaleSqrt()
    .domain([0, d3.max(data, (d: any) => d.total_occurrences) as number])
    .range([4, 26]);

  // Grid lines
  const gridColor = '#1a1a1a';
  [0.25, 0.5, 0.75].forEach(v => {
    svg.append('line')
      .attr('x1', xScale(v)).attr('x2', xScale(v))
      .attr('y1', pad.top).attr('y2', H - pad.bottom)
      .attr('stroke', gridColor).attr('stroke-width', 1);
    svg.append('line')
      .attr('x1', pad.left).attr('x2', W - pad.right)
      .attr('y1', yScale(v)).attr('y2', yScale(v))
      .attr('stroke', gridColor).attr('stroke-width', 1);
  });

  // Axes
  svg.append('g').attr('transform', `translate(0,${H - pad.bottom})`)
    .call(d3.axisBottom(xScale).ticks(5).tickFormat(d3.format('.1f')))
    .call(g => {
      g.select('.domain').attr('stroke', '#2a2a2a');
      g.selectAll('text').attr('fill', '#555').attr('font-size', 10);
      g.selectAll('line').attr('stroke', '#2a2a2a');
    });
  svg.append('g').attr('transform', `translate(${pad.left},0)`)
    .call(d3.axisLeft(yScale).ticks(5).tickFormat(d3.format('.1f')))
    .call(g => {
      g.select('.domain').attr('stroke', '#2a2a2a');
      g.selectAll('text').attr('fill', '#555').attr('font-size', 10);
      g.selectAll('line').attr('stroke', '#2a2a2a');
    });

  // Axis labels
  svg.append('text').attr('x', W/2).attr('y', H - 5)
    .attr('text-anchor', 'middle').attr('fill', '#555').attr('font-size', 10)
    .text('Recency →');
  svg.append('text').attr('transform', 'rotate(-90)')
    .attr('x', -(H/2)).attr('y', 14)
    .attr('text-anchor', 'middle').attr('fill', '#555').attr('font-size', 10)
    .text('Composite Score →');

  // "Emerging signal" quadrant label
  svg.append('text').attr('x', pad.left + 6).attr('y', pad.top + 14)
    .attr('fill', '#2a2a2a').attr('font-size', 9).attr('class', 'mono')
    .text('HIGH SIGNAL');

  const tooltip = document.getElementById('board-tooltip')!;

  svg.selectAll('circle')
    .data(data)
    .join('circle')
    .attr('cx', (d: any) => xScale(d.recency_score))
    .attr('cy', (d: any) => yScale(d.composite_score))
    .attr('r',  (d: any) => rScale(d.total_occurrences))
    .attr('fill',         (d: any) => SHAPE_COLOR[d.trend_shape] || '#444')
    .attr('fill-opacity', 0.65)
    .attr('stroke',       (d: any) => SHAPE_COLOR[d.trend_shape] || '#444')
    .attr('stroke-width', 1)
    .style('cursor', 'pointer')
    .on('mousemove', (event: MouseEvent, d: any) => {
      const box = document.getElementById('board-chart')!.getBoundingClientRect();
      tooltip.style.display = 'block';
      tooltip.style.left = `${event.clientX - box.left + 12}px`;
      tooltip.style.top  = `${event.clientY - box.top  - 10}px`;
      const journalStr = d.journals?.join(', ') || '';
      tooltip.innerHTML = `
        <p style="color:#e8e8e8;font-weight:600;margin-bottom:4px;">${d.keyword}</p>
        <p style="color:#888;font-size:11px;">score: ${d.composite_score.toFixed(2)} · ${d.trend_shape}</p>
        <p style="color:#888;font-size:11px;">${d.total_occurrences} papers · driver: ${d.primary_driver}</p>
        ${journalStr ? `<p style="color:#555;font-size:10px;margin-top:4px;">${journalStr}</p>` : ''}
      `;
    })
    .on('mouseleave', () => { tooltip.style.display = 'none'; })
    .on('click', (_: any, d: any) => openDrill(d));
}

// ── Drill-down ────────────────────────────────────────────────────────────────
function openDrill(d: any) {
  const panel = document.getElementById('drill-panel')!;
  panel.style.display = 'block';
  document.getElementById('drill-keyword')!.textContent = d.keyword;
  document.getElementById('drill-meta')!.textContent =
    `${d.trend_shape} · score ${d.composite_score.toFixed(2)} · ${d.total_occurrences} papers · driver: ${d.primary_driver}`;

  const scores = [
    { label: 'Momentum',      val: d.momentum_score },
    { label: 'Acceleration',  val: d.acceleration_score },
    { label: 'Recency',       val: d.recency_score },
    { label: 'Cit. Velocity', val: d.citation_velocity_score },
  ];
  document.getElementById('drill-scores')!.innerHTML = scores.map(s => `
    <div style="background:#0f0f0f;border:1px solid #2a2a2a;border-radius:6px;padding:10px;">
      <p style="color:#555;font-size:10px;margin-bottom:4px;" class="mono">${s.label.toUpperCase()}</p>
      <p style="color:#e8e8e8;font-size:18px;font-weight:600;">${s.val.toFixed(2)}</p>
      <div style="margin-top:6px;height:3px;background:#2a2a2a;border-radius:2px;">
        <div style="height:3px;background:#7fff6e;border-radius:2px;width:${s.val*100}%;"></div>
      </div>
    </div>
  `).join('');

  const freq  = d.frequency_by_year ?? {};
  const years = Object.keys(freq).sort();
  const vals  = years.map(y => freq[y]);
  const maxV  = Math.max(...vals, 1);

  const drillSvg = d3.select('#drill-svg');
  drillSvg.selectAll('*').remove();
  const W = (document.getElementById('drill-chart')?.getBoundingClientRect().width) || 600;
  const H = 180;
  const pad = { top: 10, right: 10, bottom: 30, left: 40 };

  const xBand = d3.scaleBand().domain(years).range([pad.left, W - pad.right]).padding(0.25);
  const yLin  = d3.scaleLinear().domain([0, maxV]).range([H - pad.bottom, pad.top]);

  drillSvg.attr('viewBox', `0 0 ${W} ${H}`)
    .selectAll('rect').data(years).join('rect')
    .attr('x',      (y: string) => xBand(y)!)
    .attr('y',      (y: string) => yLin(freq[y]))
    .attr('width',  xBand.bandwidth())
    .attr('height', (y: string) => H - pad.bottom - yLin(freq[y]))
    .attr('fill', '#7fff6e').attr('fill-opacity', 0.8).attr('rx', 2);

  drillSvg.append('g').attr('transform', `translate(0,${H - pad.bottom})`)
    .call(d3.axisBottom(xBand))
    .call(g => { g.select('.domain').attr('stroke', '#2a2a2a'); g.selectAll('text').attr('fill', '#555').attr('font-size', 10); g.selectAll('line').attr('stroke', '#2a2a2a'); });
  drillSvg.append('g').attr('transform', `translate(${pad.left},0)`)
    .call(d3.axisLeft(yLin).ticks(4))
    .call(g => { g.select('.domain').attr('stroke', '#2a2a2a'); g.selectAll('text').attr('fill', '#555').attr('font-size', 10); g.selectAll('line').attr('stroke', '#2a2a2a'); });

  document.getElementById('drill-close')!.onclick = () => { panel.style.display = 'none'; };
  panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ── Trends table ──────────────────────────────────────────────────────────────
function drawTrends() {
  renderTrendsTable();
  document.getElementById('trends-search')?.addEventListener('input', renderTrendsTable);
  document.getElementById('trends-shape')?.addEventListener('change', renderTrendsTable);
}

function renderTrendsTable() {
  const search = (document.getElementById('trends-search') as HTMLInputElement)?.value.toLowerCase() || '';
  const shape  = (document.getElementById('trends-shape')  as HTMLSelectElement)?.value || '';
  const body   = document.getElementById('trends-body')!;

  const data = activeKeywords();
  if (data.length === 0) {
    body.innerHTML = '<tr><td colspan="8" style="color:#555;padding:20px 0;font-size:12px;">No data yet.</td></tr>';
    return;
  }

  const filtered = data.filter((d: any) =>
    (!search || d.keyword.toLowerCase().includes(search)) &&
    (!shape  || d.trend_shape === shape)
  );

  body.innerHTML = filtered.map((d: any) => {
    const c = SHAPE_COLOR[d.trend_shape] || '#888';
    const journalStr = (d.journals ?? []).join(', ');
    return `
      <tr style="border-bottom:1px solid #1e1e1e;cursor:pointer;"
          onclick="window._drillItem && window._drillItem('${d.keyword.replace(/'/g, "\\'")}')">
        <td class="py-3 pr-6" style="color:#e8e8e8;font-size:12px;">${d.keyword}</td>
        <td class="mono text-right py-3 px-3" style="color:#7fff6e;">${d.composite_score.toFixed(2)}</td>
        <td class="mono text-right py-3 px-3" style="color:#555;">${d.momentum_score.toFixed(2)}</td>
        <td class="mono text-right py-3 px-3" style="color:#555;">${d.acceleration_score.toFixed(2)}</td>
        <td class="mono text-right py-3 px-3" style="color:#555;">${d.recency_score.toFixed(2)}</td>
        <td class="mono text-right py-3 px-3" style="color:#555;">${d.citation_velocity_score.toFixed(2)}</td>
        <td class="mono py-3 px-3 text-xs" style="color:${c};">${d.trend_shape}</td>
        <td class="mono py-3 px-3 text-xs" style="color:#444;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${journalStr}">${journalStr}</td>
      </tr>
    `;
  }).join('');
}

(window as any)._drillItem = (keyword: string) => {
  const data = activeKeywords();
  const d = data.find((s: any) => s.keyword === keyword);
  if (d) {
    document.querySelectorAll('.tab-panel').forEach(p => ((p as HTMLElement).style.display = 'none'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active-tab'));
    document.getElementById('tab-board')!.style.display = 'block';
    document.querySelector('[data-tab="board"]')!.classList.add('active-tab');
    openDrill(d);
  }
};

// ── Concept Map ───────────────────────────────────────────────────────────────
function drawMap() {
  const W = document.getElementById('map-chart')?.getBoundingClientRect().width || 800;
  const H = 560;
  const svg = d3.select('#map-svg').attr('viewBox', `0 0 ${W} ${H}`);
  svg.selectAll('*').remove();

  if (!expansionData || expansionData.length === 0) {
    svg.append('text').attr('x', W/2).attr('y', H/2)
      .attr('text-anchor', 'middle').attr('fill', '#444').attr('font-size', 13)
      .text('Run the tracker to populate the concept map');
    return;
  }

  const allKw = activeKeywords();
  const nodeMap = new Map<string, { id: string; score: number }>();
  const links: { source: string; target: string; value: number }[] = [];

  expansionData.forEach((entry: any) => {
    if (!nodeMap.has(entry.seed)) {
      const s = allKw.find((d: any) => d.keyword === entry.seed);
      nodeMap.set(entry.seed, { id: entry.seed, score: s?.composite_score ?? 0.5 });
    }
    entry.neighbors.slice(0, 6).forEach((nb: any) => {
      if (!nodeMap.has(nb.keyword)) nodeMap.set(nb.keyword, { id: nb.keyword, score: 0 });
      links.push({ source: entry.seed, target: nb.keyword, value: nb.cooccurrence_count });
    });
  });

  const nodes = Array.from(nodeMap.values());
  const rScale = d3.scaleLinear().domain([0, 1]).range([5, 16]);
  const tooltip = document.getElementById('map-tooltip')!;
  const mapDiv  = document.getElementById('map-chart')!;

  const sim = d3.forceSimulation(nodes as any)
    .force('link', d3.forceLink(links).id((d: any) => d.id).distance(90).strength(0.4))
    .force('charge', d3.forceManyBody().strength(-180))
    .force('center', d3.forceCenter(W / 2, H / 2))
    .force('collision', d3.forceCollide().radius((d: any) => rScale(d.score) + 8));

  const link = svg.append('g').selectAll('line').data(links).join('line')
    .attr('stroke', '#2a2a2a').attr('stroke-width', 1);

  const node = svg.append('g').selectAll('g').data(nodes).join('g')
    .style('cursor', 'pointer')
    .call(d3.drag<SVGGElement, any>()
      .on('start', (event, d) => { if (!event.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
      .on('drag',  (event, d) => { d.fx = event.x; d.fy = event.y; })
      .on('end',   (event, d) => { if (!event.active) sim.alphaTarget(0); d.fx = null; d.fy = null; }) as any
    );

  node.append('circle')
    .attr('r', (d: any) => rScale(d.score))
    .attr('fill', (d: any) => {
      const sig = allKw.find((s: any) => s.keyword === d.id);
      return SHAPE_COLOR[sig?.trend_shape || ''] || '#2a2a2a';
    })
    .attr('fill-opacity', 0.85)
    .on('mousemove', (event: MouseEvent, d: any) => {
      const box = mapDiv.getBoundingClientRect();
      const sig = allKw.find((s: any) => s.keyword === d.id);
      tooltip.style.display = 'block';
      tooltip.style.left = `${event.clientX - box.left + 12}px`;
      tooltip.style.top  = `${event.clientY - box.top  - 10}px`;
      tooltip.innerHTML = `
        <p style="color:#e8e8e8;font-weight:600;">${d.id}</p>
        ${sig ? `<p style="color:#555;font-size:10px;">${sig.trend_shape} · ${sig.composite_score.toFixed(2)}</p>` : ''}
      `;
    })
    .on('mouseleave', () => { tooltip.style.display = 'none'; });

  node.append('text')
    .text((d: any) => d.id.length > 22 ? d.id.slice(0, 20) + '…' : d.id)
    .attr('font-size', 9).attr('fill', '#888')
    .attr('text-anchor', 'middle').attr('dy', (d: any) => rScale(d.score) + 12);

  sim.on('tick', () => {
    link
      .attr('x1', (d: any) => d.source.x).attr('y1', (d: any) => d.source.y)
      .attr('x2', (d: any) => d.target.x).attr('y2', (d: any) => d.target.y);
    node.attr('transform', (d: any) => `translate(${d.x},${d.y})`);
  });
}

// ── Watchlist ─────────────────────────────────────────────────────────────────
function drawWatchlist() {
  const container = document.getElementById('watch-list')!;
  if (!watchlistData || watchlistData.length === 0) {
    container.innerHTML = '<p style="color:#555;font-size:13px;">No watchlist data yet.</p>';
    return;
  }
  container.innerHTML = watchlistData.map((w: any) => `
    <div style="background:#161616;border:1px solid #2a2a2a;border-radius:8px;padding:14px;">
      <p style="color:#e8e8e8;font-size:13px;font-weight:500;margin-bottom:6px;">${w.keyword}</p>
      <p class="mono" style="color:#555;font-size:10px;">freq: ${w.raw_frequency} · ${w.method}</p>
      <p class="mono" style="color:#f5c842;font-size:9px;margin-top:4px;">on radar</p>
    </div>
  `).join('');
}

