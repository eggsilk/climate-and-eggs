    background: #2a4226;
    border-color: #7fff6e;
    color: #7fff6e;
  }
  .domain-btn {
    background: #161616;
    border: 1px solid #2a2a2a;
    color: #888;
    transition: color 0.15s, border-color 0.15s;
  }
  .domain-btn:hover { color: #e8e8e8; }
  .active-domain {
    background: #1a1a1a;
    border-color: #7fff6e;
    color: #7fff6e;
  }
`;
document.head.appendChild(style);

loadAll();
</script>
